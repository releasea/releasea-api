# Server
PORT=8070

# Database
MONGO_URI=mongodb://localhost:27017/releasea
MONGO_TLS_INSECURE=false

# Authentication
JWT_SECRET=change-me
JWT_TTL_MINUTES=720
JWT_REFRESH_SECRET=
JWT_REFRESH_TTL_HOURS=720
WORKER_JWT_SECRET=change-me
WORKER_JWT_TTL_MINUTES=30

# Initial setup and templates
# Destructive reset/restore on startup (default false)
RELEASEA_RESET=false
INSTALL_TEMPLATES=true
TEMPLATE_REPO_OWNER=releasea
TEMPLATE_REPO_NAME=templates
TEMPLATE_REPO_REF=main

# Queue and workers
RABBITMQ_URL=amqp://releasea:releasea@localhost:5672/
WORKER_QUEUE=releasea.worker
WORKER_QUEUE_DLQ_ENABLE=true
WORKER_QUEUE_DLQ_NAME=releasea.worker.dead-letter
WORKER_STALE_SECONDS=90

# Observability
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
STATUS_STREAM_POLL_SECONDS=15

# Platform routing and static metrics
RELEASEA_SYSTEM_NAMESPACE=releasea-system
RELEASEA_STATIC_NGINX_WORKLOAD=releasea-static-nginx
RELEASEA_STATIC_METRICS_SCOPE=aggregate
RELEASEA_INTERNAL_DOMAIN=releasea.internal
RELEASEA_EXTERNAL_DOMAIN=releasea.external
RELEASEA_INTERNAL_GATEWAY=istio-system/releasea-internal-gateway
RELEASEA_EXTERNAL_GATEWAY=istio-system/releasea-external-gateway
RELEASEA_NAMESPACE_MAPPING=

# Identity bootstrap defaults
DEFAULT_TEAM_ID=team-1
DEFAULT_TEAM_NAME=Platform
DEFAULT_ADMIN_ID=user-1
DEFAULT_ADMIN_NAME=Platform Admin
DEFAULT_ADMIN_EMAIL=admin@releasea.io
DEFAULT_ADMIN_PASSWORD=releasea

# Access policy
ALLOW_USER_SIGNUP=false
KEEP_ADDITIONAL_USERS=false

# Optional webhooks and SSO
RELEASEA_NOTIFICATIONS_WEBHOOK_URL=
NOTIFICATIONS_WEBHOOK_URL=
AUTH_SSO_CALLBACK_URL=
AUTH_SSO_REDIRECT_URL=
CORS_ORIGINS=

# Optional RabbitMQ TLS
RABBITMQ_TLS_MODE=auto
RABBITMQ_TLS_REQUIRE=false
RABBITMQ_ALLOW_INSECURE_IN_PRODUCTION=false
RABBITMQ_TLS_ENABLE=false
RABBITMQ_TLS_SERVER_NAME=
RABBITMQ_TLS_CA_PATH=
RABBITMQ_TLS_CERT_PATH=
RABBITMQ_TLS_KEY_PATH=
RABBITMQ_TLS_INSECURE=false

# Optional debug flags
RELEASEA_DEBUG_CREDENTIALS=false
WORKER_DEBUG_CREDENTIALS=false
